[user]
  name = Maurício Braz Gonçalves
  email = mauriciobraz@proton.me

[includeIf "gitdir:~/Code/fattureweb/"]
path = ~/Code/fattureweb/.gitconfig

[includeIf "gitdir:~/Code/mauriciobraz/"]
path = ~/Code/mauriciobraz/.gitconfig

[gpg]
  format = ssh

[gpg "ssh"]
  program = "/opt/1Password/op-ssh-sign"

[core]
  excludesFile = "~/.gitignore"

[color]
  ui = true
  diff = auto
  status = auto
